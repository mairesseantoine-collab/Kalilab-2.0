# ============================================================
# KaliLab - Configuration exemple
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=kalilab
POSTGRES_USER=kalilab
POSTGRES_PASSWORD=ChangeMe2024!

# --- Backend FastAPI ---
DATABASE_URL=postgresql+asyncpg://kalilab:ChangeMe2024!@postgres:5432/kalilab
SECRET_KEY=change-this-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# --- MinIO (stockage fichiers) ---
S3_ENDPOINT=http://minio:9000
S3_BUCKET=kalilab-docs
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=ChangeMinioSecret2024!

# --- Frontend (production build) ---
# En dev Docker : VITE_API_URL=http://localhost:8000
# En prod nginx  : VITE_API_URL=/api  (proxy nginx)
VITE_API_URL=/api
